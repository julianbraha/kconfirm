
config X
    def_bool y
    help
        blah blah
        this website should always be available: https://www.google.com/generate_204

config Y
    bool "y"
    default n if X

config MODULES
    bool
    modules

config Z
    tristate "z"
    depends on X

config A
    def_bool y
    select MODULES
    imply Z

if A

config B
    int

config C
    int "c"
    range 0 2

endif # A

choice
    prompt "this is a choice"
    depends on X
    default D

    config D
        bool "d"

    config E
        bool "e"
endchoice
